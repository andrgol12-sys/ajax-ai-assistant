# Токен Telegram-бота от @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Authorization key для Basic-авторизации (из личного кабинета GigaChat)
GIGACHAT_AUTHORIZATION_KEY=your_gigachat_authorization_key

# Область доступа (по умолчанию для физлиц)
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Модель GigaChat
GIGACHAT_MODEL=GigaChat

# Проверка SSL-сертификатов (для API Сбера часто false)
GIGACHAT_VERIFY_SSL=false

# Системный промпт (необязательно; по умолчанию — помощник ООО «АЯКС»)
# GIGACHAT_SYSTEM_PROMPT=
